generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Participant {
  id          Int        @id @default(autoincrement())
  firstName   String     @map("first_name")
  lastName    String     @map("last_name")
  dob         DateTime   @db.Date
  sex         Sex
  weightValue Decimal    @map("weight_value") @db.Decimal(7, 3)
  weightUnit  WeightUnit @map("weight_unit")
  heightValue Decimal    @map("height_value") @db.Decimal(6, 2)
  heightUnit  HeightUnit @map("height_unit")
  bmi         Decimal    @db.Decimal(4, 1)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)
  weightKg   Decimal    @default(dbgenerated("\nCASE weight_unit\n    WHEN 'kg'::\"WeightUnit\" THEN weight_value\n    ELSE (weight_value * 0.45359237)\nEND")) @map("weight_kg") @db.Decimal(9, 4)
  weightLb   Decimal    @default(dbgenerated("\nCASE weight_unit\n    WHEN 'lb'::\"WeightUnit\" THEN weight_value\n    ELSE (weight_value / 0.45359237)\nEND")) @map("weight_lb") @db.Decimal(9, 4)
  heightCm   Decimal    @default(dbgenerated("\nCASE height_unit\n    WHEN 'cm'::\"HeightUnit\" THEN height_value\n    ELSE (height_value * 2.54)\nEND")) @map("height_cm") @db.Decimal(6, 2)
  heightIn   Decimal    @default(dbgenerated("\nCASE height_unit\n    WHEN 'in'::\"HeightUnit\" THEN height_value\n    ELSE (height_value / 2.54)\nEND")) @map("height_in") @db.Decimal(6, 2)
  fullName   String     @default(dbgenerated("lower((first_name || ' '::text) || last_name)")) @map("full_name")
  contact     Contact?

  @@index([bmi])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([fullName])
  @@map("participant")
}

model Contact {
  id            Int         @id @default(autoincrement())
  participantId Int         @unique @map("participant_id")
  phone         String?
  email         String?
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?   @map("deleted_at") @db.Timestamptz(6)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId])
  @@map("contact")
}

enum Sex {
  male
  female
}

enum WeightUnit {
  kg
  lb
}

enum HeightUnit {
  cm
  in
}
