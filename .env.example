# Committed template — copy to .env and adjust for your environment.
# The default matches the local Postgres in docker-compose.yml (npm run db:up).
DATABASE_URL="postgresql://bmi:bmi@localhost:5432/bmi?schema=public"

# Timezone applied to both the Next.js server process and the Postgres container.
# Keep UTC unless you have a specific reason; timestamps are stored in UTC regardless.
TZ="UTC"
