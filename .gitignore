# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# local secrets (service-account keys, etc.) — never commit
/.secrets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.temp/*

# Auto-copied by scripts/copy-pdfjs-worker.mjs
/public/pdf.worker.min.mjs
.claude/worktrees/*
.vscode

# conversion-service build output
conversion-service/dist
conversion-service/node_modules


# superpowers SDD scratch (task/trial reports, progress ledger)
.superpowers/
