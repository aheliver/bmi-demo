    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.5",
    "eslint": "^9",
    "shadcn": "^4.13.0",
    "eslint-config-next": "16.2.6",
    "happy-dom": "^20.10.6",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
